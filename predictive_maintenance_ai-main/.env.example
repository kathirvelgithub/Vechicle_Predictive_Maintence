# ============================================
# DATABASE CONFIGURATION (Local PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/predictive_maintenance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=predictive_maintenance
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_CONNECT_TIMEOUT_SECONDS=5
DB_STATEMENT_TIMEOUT_MS=8000
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# AI/LLM CONFIGURATION
# ============================================
# Groq API Key for Llama 3.3 70B
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Phase 2 model gateway controls (optional)
AGENT_MODEL_DEFAULT=llama-3.3-70b-versatile
AGENT_MODEL_FALLBACK=llama-3.1-8b-instant
# Model spec format supports provider prefixes: groq:<model>, openai:<model>, ollama:<model>
# Plain model names default to Groq for backward compatibility.
# AGENT_MODELS_DIAGNOSIS=groq:llama-3.3-70b-versatile,groq:llama-3.1-8b-instant,ollama:llama3.1:8b
# AGENT_MODELS_CUSTOMER=llama-3.1-8b-instant,llama-3.3-70b-versatile
# AGENT_MODELS_VOICE=llama-3.1-8b-instant,llama-3.3-70b-versatile
# AGENT_MODELS_FEEDBACK=llama-3.1-8b-instant,llama-3.3-70b-versatile
# AGENT_MODELS_MANUFACTURING=llama-3.3-70b-versatile,llama-3.1-8b-instant
LLM_TIMEOUT_SECONDS=25
LLM_RETRIES_PER_MODEL=2
LLM_RETRY_BACKOFF_SECONDS=1.0

# Hybrid risk scoring (XGBoost + rule guardrails)
ML_RISK_ENABLED=true
ML_RISK_MODEL_PATH=app/models/risk_xgb.pkl
ML_RISK_BLEND_WEIGHT=0.7

# Startup readiness controls
# Use strict defaults for demo/prod confidence. Override to false in local dev if needed.
STARTUP_STRICT_READINESS=true
STARTUP_REQUIRE_ML_MODEL=true

# Queue safeguards
ESCALATION_AGENT_TIMEOUT_SECONDS=45

# Optional OpenAI-compatible local Llama via Ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_API_KEY=ollama

# Alternative: OpenAI
OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# LangChain
LANGCHAIN_API_KEY=your_langchain_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=predictive-maintenance

# ============================================
# MQTT/IoT CONFIGURATION (Optional)
# ============================================
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_TOPIC=vehicle/telematics/#

# ============================================
# SECURITY
# ============================================
JWT_SECRET_KEY=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=development
DEBUG=True
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175

# ============================================
# EXTERNAL SERVICES
# ============================================
# If you need Supabase as backup (optional)
# SUPABASE_URL=your_supabase_url
# SUPABASE_KEY=your_supabase_key
