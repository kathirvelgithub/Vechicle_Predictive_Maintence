# ============================================
# DATABASE CONFIGURATION (Local PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/predictive_maintenance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_DB=predictive_maintenance
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================
# AI/LLM CONFIGURATION
# ============================================
# Groq API Key for Llama 3.3 70B
GROQ_API_KEY=your_groq_api_key_here

# Alternative: OpenAI
OPENAI_API_KEY=your_openai_key_here

# LangChain
LANGCHAIN_API_KEY=your_langchain_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=predictive-maintenance

# ============================================
# MQTT/IoT CONFIGURATION (Optional)
# ============================================
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_TOPIC=vehicle/telematics/#

# ============================================
# SECURITY
# ============================================
JWT_SECRET_KEY=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=development
DEBUG=True
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# EXTERNAL SERVICES
# ============================================
# If you need Supabase as backup (optional)
# SUPABASE_URL=your_supabase_url
# SUPABASE_KEY=your_supabase_key
